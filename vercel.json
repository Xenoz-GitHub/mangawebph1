{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {"src": "**/*.html", "use": "@vercel/static"},
    {"src": "images/**/*", "use": "@vercel/static"},
    {"src": "css/**/*", "use": "@vercel/static"},
    {"src": "js/**/*", "use": "@vercel/static"}
  ],
  "routes": [
    {"src": "/", "dest": "/index.html"},
    {"src": "/pages/(.*)", "dest": "/pages/$1"},
    {"src": "/images/(.*)", "dest": "/images/$1"},
    {"src": "/css/(.*)", "dest": "/css/$1"},
    {"src": "/js/(.*)", "dest": "/js/$1"},
    {"src": "/manifest.json", "dest": "/manifest.json"},
    {"src": "/(.*)", "dest": "/$1"}
  ]
}
